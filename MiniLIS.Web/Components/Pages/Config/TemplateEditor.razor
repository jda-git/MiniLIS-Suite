@page "/configuracion/plantillas/{TemplateId:int?}"
@using MiniLIS.Application.Interfaces
@using MiniLIS.Domain.Entities
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Administrador")]
@inject IMasterDataService MasterService
@inject NavigationManager Nav

<PageTitle>Editor de Plantilla - MiniLIS Suite</PageTitle>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <button class="btn btn-link link-secondary p-0" @onclick='() => Nav.NavigateTo("/configuracion")'>
            <i class="bi bi-arrow-left me-1"></i> Volver a Configuración
        </button>
        <h1 class="h3 fw-bold mb-0">@(template.Id == 0 ? "Nueva Plantilla" : "Editar Plantilla: " + template.Name)</h1>
    </div>

    <div class="row g-4">
        <!-- Main Edit Form -->
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4">Ajustes Generales</h5>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Nombre de la Plantilla</label>
                        <input type="text" @bind="template.Name" class="form-control" placeholder="Ej: SMD, LNH..." />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Texto Predefinido (Cuerpo Informe)</label>
                        <textarea @bind="template.HeaderText" class="form-control" rows="4" placeholder="En la muestra analizada se observa..."></textarea>
                    </div>
                    <div class="mb-0">
                        <label class="form-label fw-semibold">Conclusión Estándar</label>
                        <textarea @bind="template.DefaultConclusion" class="form-control" rows="3" placeholder="Compatible con..."></textarea>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="fw-bold mb-0">Orden de Marcadores (Rejilla)</h5>
                        <span class="badge bg-light text-dark border small">Utiliza Arrastrar y Soltar</span>
                    </div>

                    <div class="marker-sort-list">
                        @if (!selectedMarkers.Any())
                        {
                            <div class="text-center py-5 border border-dashed rounded-3 text-muted">
                                <i class="bi bi-card-list h2 d-block"></i> No hay marcadores asignados.
                            </div>
                        }
                        else
                        {
                            @foreach (var tm in selectedMarkers.OrderBy(x => x.DisplayOrder))
                            {
                                <div class="marker-item p-3 mb-2 bg-white border rounded shadow-sm d-flex align-items-center"
                                     draggable="true"
                                     @ondragstart="@(() => HandleDragStart(tm))"
                                     @ondragover:prevent_default
                                     @ondragover="@(() => HandleDragOver(tm))"
                                     @ondrop="@(() => HandleDrop(tm))">
                                    <i class="bi bi-grip-vertical text-muted me-3 fs-5"></i>
                                    <div class="flex-grow-1 fw-bold">@tm.Marker.Name</div>
                                    <button class="btn btn-outline-danger btn-sm border-0" @onclick="() => RemoveMarker(tm)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar: Add Markers Selection -->
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm rounded-4 sticky-top" style="top: 1rem;">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3">Catálogo de Marcadores</h5>
                    <div class="input-group mb-3">
                        <span class="input-group-text bg-white border-end-0"><i class="bi bi-search"></i></span>
                        <input type="text" class="form-control border-start-0" placeholder="Buscar CD..." @bind="searchQuery" @bind:event="oninput" />
                    </div>
                    
                    <div class="marker-selection-list list-group list-group-flush overflow-auto" style="max-height: 400px;">
                        @foreach (var m in allMarkers.Where(x => x.Name.Contains(searchQuery, StringComparison.OrdinalIgnoreCase)))
                        {
                            var isAlreadyIn = selectedMarkers.Any(sm => sm.MarkerId == m.Id);
                            <button class="list-group-item list-group-item-action d-flex justify-content-between align-items-center @(isAlreadyIn ? "disabled text-muted bg-light" : "")"
                                    @onclick="() => AddMarker(m)">
                                <span>@m.Name</span>
                                @if (isAlreadyIn)
                                {
                                    <i class="bi bi-check-circle-fill text-success"></i>
                                }
                                else
                                {
                                    <i class="bi bi-plus-circle text-primary"></i>
                                }
                            </button>
                        }
                    </div>

                    <div class="mt-4 pt-3 border-top">
                        <button class="btn btn-primary w-100 py-2 fw-bold shadow-sm" @onclick="SaveTemplate" disabled="@isSaving">
                            @if (isSaving) { <span class="spinner-border spinner-border-sm me-2"></span> }
                            <i class="bi bi-save me-2"></i> Guardar Plantilla
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .marker-item { cursor: grab; transition: transform 0.1s; }
    .marker-item:active { cursor: grabbing; transform: scale(0.98); }
    .marker-item:hover { border-color: #0d6efd !important; }
    .list-group-item { cursor: pointer; }
    .border-dashed { border-style: dashed !important; border-width: 2px !important; }
</style>

@code {
    [Parameter] public int? TemplateId { get; set; }

    private ReportTemplate template = new();
    private List<Marker> allMarkers = new();
    private List<TemplateMarker> selectedMarkers = new();
    private string searchQuery = "";
    private bool isSaving = false;

    // DnD State
    private TemplateMarker? draggedItem;

    protected override async Task OnInitializedAsync()
    {
        allMarkers = await MasterService.GetAllMarkersAsync();

        if (TemplateId.HasValue && TemplateId > 0)
        {
            var existing = await MasterService.GetTemplateWithMarkersAsync(TemplateId.Value);
            if (existing != null)
            {
                template = existing;
                selectedMarkers = existing.Markers.ToList();
            }
        }
    }

    private void AddMarker(Marker marker)
    {
        if (selectedMarkers.Any(m => m.MarkerId == marker.Id)) return;

        selectedMarkers.Add(new TemplateMarker
        {
            MarkerId = marker.Id,
            Marker = marker,
            DisplayOrder = selectedMarkers.Any() ? selectedMarkers.Max(x => x.DisplayOrder) + 1 : 1
        });
    }

    private void RemoveMarker(TemplateMarker tm)
    {
        selectedMarkers.Remove(tm);
        ReorderMarkers();
    }

    private void ReorderMarkers()
    {
        var ordered = selectedMarkers.OrderBy(x => x.DisplayOrder).ToList();
        for (int i = 0; i < ordered.Count; i++)
        {
            ordered[i].DisplayOrder = i + 1;
        }
    }

    // --- Drag and Drop Logic ---
    private void HandleDragStart(TemplateMarker item)
    {
        draggedItem = item;
    }

    private void HandleDragOver(TemplateMarker item)
    {
        if (draggedItem == null || draggedItem == item) return;
        
        // Visual cue or real-time swap
    }

    private void HandleDrop(TemplateMarker targetItem)
    {
        if (draggedItem == null || draggedItem == targetItem) return;

        int oldIndex = draggedItem.DisplayOrder;
        int newIndex = targetItem.DisplayOrder;

        draggedItem.DisplayOrder = newIndex;
        targetItem.DisplayOrder = oldIndex;

        ReorderMarkers();
        draggedItem = null;
    }

    private async Task SaveTemplate()
    {
        isSaving = true;
        try
        {
            await MasterService.UpsertTemplateAsync(template, selectedMarkers);
            Nav.NavigateTo("/configuracion");
        }
        catch (Exception ex)
        {
            // Error handling
        }
        finally
        {
            isSaving = false;
        }
    }
}
