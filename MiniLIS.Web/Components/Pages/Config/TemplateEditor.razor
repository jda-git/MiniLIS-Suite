@page "/configuracion/plantillas/{TemplateId:int?}"
@page "/configuracion/plantilla/{TemplateId:int?}"
@page "/configuracion/plantilla/nueva"
@using MiniLIS.Application.Interfaces
@using MiniLIS.Domain.Entities
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Administrador")]
@inject IMasterDataService MasterService
@inject NavigationManager Nav

<PageTitle>Editor de Plantilla - MiniLIS Suite</PageTitle>

<div class="tpl-page">

    <!-- Header -->
    <div class="tpl-header">
        <div class="tpl-header-left">
            <button class="btn-back" @onclick='() => Nav.NavigateTo("/configuracion")'>
                <i class="bi bi-arrow-left"></i> Configuración
            </button>
            <h1 class="tpl-title">
                <i class="bi bi-file-earmark-medical"></i>
                @(template.Id == 0 ? "Nueva Plantilla" : template.Name)
            </h1>
            @if (template.Id > 0)
            {
                <span class="tpl-id-badge">ID: @template.Id</span>
            }
        </div>
        <button class="btn-tpl btn-tpl-save" @onclick="SaveTemplate" disabled="@isSaving">
            @if (isSaving) { <span class="spinner-border spinner-border-sm me-2"></span> }
            <i class="bi bi-save"></i> Guardar Plantilla
        </button>
    </div>

    <div class="tpl-layout">

        <!-- ═══ LEFT COLUMN ═══ -->
        <div class="tpl-main">

            <!-- Ajustes Generales -->
            <div class="tpl-card">
                <div class="tpl-card-header">
                    <div class="tpl-card-icon"><i class="bi bi-sliders"></i></div>
                    <h2 class="tpl-card-title">Ajustes Generales</h2>
                </div>
                <div class="tpl-card-body">
                    <div class="tpl-field">
                        <label class="tpl-label">Nombre de la Plantilla</label>
                        <input type="text" @bind="template.Name" class="tpl-input" placeholder="Ej: SMD, LNH..." />
                    </div>
                    <div class="tpl-field">
                        <label class="tpl-label">Texto Predefinido (Cuerpo Informe)</label>
                        <textarea @bind="template.HeaderText" class="tpl-input tpl-textarea" rows="4" placeholder="En la muestra analizada se observa..."></textarea>
                    </div>
                    <div class="tpl-field">
                        <label class="tpl-label">Conclusión Estándar (Por defecto)</label>
                        <textarea @bind="template.DefaultConclusion" class="tpl-input tpl-textarea" rows="3" placeholder="Compatible con..."></textarea>
                    </div>
                </div>
            </div>

            <!-- Conclusiones Predefinidas -->
            <div class="tpl-card">
                <div class="tpl-card-header">
                    <div class="tpl-card-icon icon-purple"><i class="bi bi-chat-quote"></i></div>
                    <div>
                        <h2 class="tpl-card-title">Conclusiones Predefinidas</h2>
                        <p class="tpl-card-subtitle">Opciones del desplegable al usar esta plantilla</p>
                    </div>
                    <button class="btn-tpl btn-tpl-outline ms-auto" @onclick="AddConclusion">
                        <i class="bi bi-plus-lg"></i> Añadir
                    </button>
                </div>
                <div class="tpl-card-body">
                    @if (!conclusions.Any() && !showNewConclusionForm)
                    {
                        <div class="tpl-empty">
                            <i class="bi bi-chat-left-dots"></i>
                            <span>Sin conclusiones predefinidas</span>
                        </div>
                    }
                    else
                    {
                        <div class="conclusions-list">
                            @foreach (var c in conclusions.OrderBy(x => x.DisplayOrder))
                            {
                                <div class="conclusion-item">
                                    <div class="conclusion-number">@c.DisplayOrder</div>
                                    @if (editingConclusionId == c.Id)
                                    {
                                        <textarea class="tpl-input tpl-textarea conclusion-edit-input" rows="2" @bind="editingConclusionText"></textarea>
                                        <div class="conclusion-edit-actions">
                                            <button type="button" class="action-icon action-save" @onclick="() => SaveEditedConclusion(c)"><i class="bi bi-check-lg"></i></button>
                                            <button type="button" class="action-icon action-cancel" @onclick="() => editingConclusionId = 0"><i class="bi bi-x-lg"></i></button>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="conclusion-text">@c.Text</div>
                                        <div class="conclusion-actions">
                                            <button type="button" class="action-icon action-edit" @onclick="() => StartEditConclusion(c)" title="Editar"><i class="bi bi-pencil"></i></button>
                                            <button type="button" class="action-icon action-delete" @onclick="() => DeleteConclusion(c.Id)" title="Eliminar"><i class="bi bi-trash"></i></button>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }

                    @if (showNewConclusionForm)
                    {
                        <div class="conclusion-new-form">
                            <textarea class="tpl-input tpl-textarea" rows="2" @bind="newConclusionText" placeholder="Texto de la conclusión predefinida..."></textarea>
                            <div class="conclusion-new-actions">
                                <button class="btn-tpl btn-tpl-success" @onclick="SaveNewConclusion"><i class="bi bi-check-lg"></i> Guardar</button>
                                <button class="btn-tpl btn-tpl-ghost" @onclick="() => showNewConclusionForm = false">Cancelar</button>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Orden de Marcadores -->
            <div class="tpl-card">
                <div class="tpl-card-header">
                    <div class="tpl-card-icon icon-green"><i class="bi bi-sort-numeric-down"></i></div>
                    <div>
                        <h2 class="tpl-card-title">Orden de Marcadores</h2>
                        <p class="tpl-card-subtitle">Arrastra para reordenar la rejilla del informe</p>
                    </div>
                    <span class="marker-count-badge ms-auto">@selectedMarkers.Count asignados</span>
                </div>
                <div class="tpl-card-body">
                    @if (!selectedMarkers.Any())
                    {
                        <div class="tpl-empty">
                            <i class="bi bi-grid-3x3"></i>
                            <span>Selecciona marcadores del catálogo →</span>
                        </div>
                    }
                    else
                    {
                        <div class="markers-sort-grid">
                            @foreach (var tm in selectedMarkers.OrderBy(x => x.DisplayOrder))
                            {
                                <div @key="tm.MarkerId"
                                     draggable="true"
                                     @ondragstart="@(() => HandleDragStart(tm))"
                                     @ondragover:preventDefault
                                     @ondragenter:preventDefault
                                     @ondrop="@(() => HandleDrop(tm))"
                                     class="marker-sort-item @(draggedItem == tm ? "is-dragging" : "")">
                                    <i class="bi bi-grip-vertical drag-handle"></i>
                                    <span class="marker-sort-order">@tm.DisplayOrder</span>
                                    <span class="marker-sort-name">@tm.Marker.Name</span>
                                    <button type="button" class="marker-sort-remove" @onclick="() => RemoveMarker(tm)">
                                        <i class="bi bi-x"></i>
                                    </button>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- ═══ RIGHT COLUMN (Sidebar) ═══ -->
        <div class="tpl-sidebar">
            <div class="tpl-card tpl-sidebar-card">
                <div class="tpl-card-header">
                    <div class="tpl-card-icon icon-cyan"><i class="bi bi-tag"></i></div>
                    <h2 class="tpl-card-title">Catálogo de Marcadores</h2>
                </div>
                <div class="tpl-card-body">
                    <div class="catalog-search">
                        <i class="bi bi-search"></i>
                        <input type="text" class="catalog-search-input" placeholder="Buscar CD..." @bind="searchQuery" @bind:event="oninput" />
                    </div>

                    <div class="catalog-list">
                        @foreach (var m in allMarkers.Where(x => x.Name.Contains(searchQuery, StringComparison.OrdinalIgnoreCase)))
                        {
                            var isAlreadyIn = selectedMarkers.Any(sm => sm.MarkerId == m.Id);
                            <button type="button" class="catalog-item @(isAlreadyIn ? "catalog-item-added" : "")" @onclick="() => AddMarker(m)">
                                <span class="catalog-item-name">@m.Name</span>
                                @if (isAlreadyIn)
                                {
                                    <i class="bi bi-check-circle-fill catalog-check"></i>
                                }
                                else
                                {
                                    <i class="bi bi-plus-circle catalog-add"></i>
                                }
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* ── Page ─────────────────────────────────────────────── */
    .tpl-page {
        padding: 28px 32px;
        background: #f4f6f9;
        min-height: calc(100vh - 56px);
        font-family: 'Inter', 'Segoe UI', system-ui, sans-serif;
    }

    /* ── Header ──────────────────────────────────────────── */
    .tpl-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
    }
    .tpl-header-left {
        display: flex;
        align-items: center;
        gap: 16px;
    }
    .btn-back {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        padding: 6px 14px;
        font-size: 13px;
        font-weight: 600;
        color: #64748b;
        cursor: pointer;
        transition: all 0.15s;
    }
    .btn-back:hover { background: #f1f5f9; color: #334155; border-color: #cbd5e1; }
    .tpl-title {
        font-size: 22px;
        font-weight: 800;
        color: #1e293b;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .tpl-title i { color: #3b82f6; font-size: 24px; }
    .tpl-id-badge {
        background: #f1f5f9;
        color: #94a3b8;
        font-size: 11px;
        font-weight: 700;
        padding: 3px 10px;
        border-radius: 6px;
        font-family: 'JetBrains Mono', monospace;
    }

    /* ── Buttons ──────────────────────────────────────────── */
    .btn-tpl {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        font-weight: 700;
        padding: 8px 20px;
        border-radius: 8px;
        border: none;
        cursor: pointer;
        transition: all 0.15s ease;
    }
    .btn-tpl-save {
        background: linear-gradient(135deg, #3b82f6, #2563eb);
        color: #fff;
        box-shadow: 0 2px 8px rgba(37, 99, 235, 0.25);
        padding: 10px 28px;
    }
    .btn-tpl-save:hover { box-shadow: 0 4px 14px rgba(37, 99, 235, 0.35); transform: translateY(-1px); }
    .btn-tpl-save:disabled { opacity: 0.6; transform: none; cursor: not-allowed; }
    .btn-tpl-outline {
        background: #fff;
        color: #3b82f6;
        border: 1.5px solid #bfdbfe;
    }
    .btn-tpl-outline:hover { background: #eff6ff; border-color: #3b82f6; }
    .btn-tpl-success {
        background: linear-gradient(135deg, #22c55e, #16a34a);
        color: #fff;
    }
    .btn-tpl-success:hover { box-shadow: 0 2px 8px rgba(22, 163, 74, 0.3); }
    .btn-tpl-ghost {
        background: #f1f5f9;
        color: #64748b;
        border: 1px solid #e2e8f0;
    }
    .btn-tpl-ghost:hover { background: #e2e8f0; }

    /* ── Layout ──────────────────────────────────────────── */
    .tpl-layout {
        display: grid;
        grid-template-columns: 1fr 340px;
        gap: 24px;
        align-items: start;
    }
    .tpl-main { display: flex; flex-direction: column; gap: 20px; }

    /* ── Cards ────────────────────────────────────────────── */
    .tpl-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 1px 4px rgba(0,0,0,0.04);
    }
    .tpl-card-header {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 18px 24px;
        border-bottom: 1px solid #f1f5f9;
    }
    .tpl-card-icon {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        background: #eff6ff;
        color: #3b82f6;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        flex-shrink: 0;
    }
    .tpl-card-icon.icon-purple { background: #f3e8ff; color: #7c3aed; }
    .tpl-card-icon.icon-green { background: #ecfdf5; color: #059669; }
    .tpl-card-icon.icon-cyan { background: #ecfeff; color: #0891b2; }
    .tpl-card-title { font-size: 15px; font-weight: 700; color: #1e293b; margin: 0; }
    .tpl-card-subtitle { font-size: 12px; color: #94a3b8; margin: 2px 0 0; }
    .tpl-card-body { padding: 20px 24px; }

    /* ── Form Fields ─────────────────────────────────────── */
    .tpl-field { margin-bottom: 16px; }
    .tpl-field:last-child { margin-bottom: 0; }
    .tpl-label {
        display: block;
        font-size: 11px;
        font-weight: 700;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 6px;
    }
    .tpl-input {
        width: 100%;
        border: 1px solid #e2e8f0;
        background: #fff;
        border-radius: 8px;
        padding: 10px 14px;
        font-size: 13px;
        color: #334155;
        transition: border-color 0.15s, box-shadow 0.15s;
        outline: none;
        box-sizing: border-box;
    }
    .tpl-input:focus { border-color: #3b82f6; box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1); }
    .tpl-textarea { resize: vertical; font-family: 'JetBrains Mono', 'Consolas', monospace; font-size: 12px; line-height: 1.6; }

    /* ── Empty State ──────────────────────────────────────── */
    .tpl-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        padding: 32px;
        color: #94a3b8;
        font-size: 13px;
        background: #f8fafc;
        border: 2px dashed #e2e8f0;
        border-radius: 10px;
    }
    .tpl-empty i { font-size: 28px; }

    /* ── Conclusions ──────────────────────────────────────── */
    .conclusions-list { display: flex; flex-direction: column; gap: 8px; }
    .conclusion-item {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        padding: 10px 14px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        transition: border-color 0.15s;
    }
    .conclusion-item:hover { border-color: #cbd5e1; }
    .conclusion-number {
        width: 24px;
        height: 24px;
        border-radius: 6px;
        background: #e2e8f0;
        color: #475569;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: 800;
        flex-shrink: 0;
        margin-top: 2px;
    }
    .conclusion-text { flex: 1; font-size: 13px; color: #334155; line-height: 1.5; }
    .conclusion-actions, .conclusion-edit-actions { display: flex; gap: 4px; flex-shrink: 0; }
    .conclusion-edit-input { flex: 1; }
    .conclusion-new-form {
        margin-top: 12px;
        padding: 14px;
        background: #f8fafc;
        border: 1px solid #3b82f6;
        border-radius: 8px;
    }
    .conclusion-new-form .tpl-textarea { margin-bottom: 10px; }
    .conclusion-new-actions { display: flex; gap: 8px; }

    /* ── Action Icons ────────────────────────────────────── */
    .action-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 30px;
        height: 30px;
        border-radius: 6px;
        border: 1px solid #e2e8f0;
        background: #fff;
        cursor: pointer;
        transition: all 0.15s ease;
        font-size: 13px;
    }
    .action-edit { color: #2563eb; }
    .action-edit:hover { background: #eff6ff; border-color: #93c5fd; }
    .action-delete { color: #ef4444; }
    .action-delete:hover { background: #fef2f2; border-color: #fca5a5; }
    .action-save { color: #16a34a; }
    .action-save:hover { background: #f0fdf4; border-color: #86efac; }
    .action-cancel { color: #64748b; }
    .action-cancel:hover { background: #f1f5f9; }

    /* ── Markers Sort Grid ───────────────────────────────── */
    .markers-sort-grid { display: flex; flex-direction: column; gap: 6px; }
    .marker-sort-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 14px;
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        cursor: grab;
        transition: all 0.15s ease;
    }
    .marker-sort-item:active { cursor: grabbing; transform: scale(0.99); }
    .marker-sort-item:hover { border-color: #93c5fd; box-shadow: 0 2px 8px rgba(37, 99, 235, 0.06); }
    .marker-sort-item.is-dragging {
        opacity: 0.4;
        border: 2px dashed #3b82f6;
        background: #eff6ff;
    }
    .drag-handle { color: #cbd5e1; font-size: 16px; cursor: grab; }
    .marker-sort-order {
        width: 24px;
        height: 24px;
        border-radius: 6px;
        background: #eff6ff;
        color: #2563eb;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: 800;
        flex-shrink: 0;
    }
    .marker-sort-name {
        flex: 1;
        font-size: 14px;
        font-weight: 700;
        color: #1e293b;
        font-family: 'JetBrains Mono', monospace;
    }
    .marker-sort-remove {
        width: 26px;
        height: 26px;
        border-radius: 6px;
        border: none;
        background: transparent;
        color: #cbd5e1;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.15s;
        font-size: 14px;
    }
    .marker-sort-remove:hover { background: #fef2f2; color: #ef4444; }
    .marker-count-badge {
        background: #ecfdf5;
        color: #059669;
        font-size: 11px;
        font-weight: 700;
        padding: 4px 12px;
        border-radius: 20px;
        border: 1px solid #bbf7d0;
    }

    /* ── Sidebar ──────────────────────────────────────────── */
    .tpl-sidebar-card { position: sticky; top: 1rem; }

    /* ── Catalog Search ──────────────────────────────────── */
    .catalog-search {
        display: flex;
        align-items: center;
        gap: 8px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        padding: 0 12px;
        margin-bottom: 12px;
        transition: border-color 0.15s;
    }
    .catalog-search:focus-within { border-color: #3b82f6; box-shadow: 0 0 0 3px rgba(59,130,246,0.1); }
    .catalog-search i { color: #94a3b8; font-size: 14px; }
    .catalog-search-input {
        flex: 1;
        border: none;
        background: transparent;
        padding: 10px 0;
        font-size: 13px;
        color: #334155;
        outline: none;
    }
    .catalog-search-input::placeholder { color: #94a3b8; }

    /* ── Catalog List ────────────────────────────────────── */
    .catalog-list {
        display: flex;
        flex-direction: column;
        gap: 2px;
        max-height: 420px;
        overflow-y: auto;
        scrollbar-width: thin;
    }
    .catalog-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 9px 14px;
        border: none;
        background: transparent;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.12s ease;
        text-align: left;
        width: 100%;
    }
    .catalog-item:hover { background: #f1f5f9; }
    .catalog-item-name {
        font-size: 13px;
        font-weight: 600;
        color: #1e293b;
    }
    .catalog-add { color: #3b82f6; font-size: 16px; }
    .catalog-check { color: #22c55e; font-size: 16px; }
    .catalog-item-added {
        opacity: 0.5;
        cursor: default;
    }
    .catalog-item-added .catalog-item-name { color: #94a3b8; }

    /* ── Responsive ──────────────────────────────────────── */
    @@media (max-width: 1100px) {
        .tpl-layout { grid-template-columns: 1fr; }
        .tpl-sidebar-card { position: static; }
    }
</style>

@code {
    [Parameter] public int? TemplateId { get; set; }

    private ReportTemplate template = new();
    private List<Marker> allMarkers = new();
    private List<TemplateMarker> selectedMarkers = new();
    private List<TemplateConclusion> conclusions = new();
    private string searchQuery = "";
    private bool isSaving = false;

    // Conclusions form state
    private bool showNewConclusionForm = false;
    private string newConclusionText = "";
    private int editingConclusionId = 0;
    private string editingConclusionText = "";

    // DnD State
    private TemplateMarker? draggedItem;

    protected override async Task OnInitializedAsync()
    {
        allMarkers = await MasterService.GetAllMarkersAsync();

        if (TemplateId.HasValue && TemplateId > 0)
        {
            var existing = await MasterService.GetTemplateWithMarkersAsync(TemplateId.Value);
            if (existing != null)
            {
                template = existing;
                selectedMarkers = existing.Markers.ToList();
                conclusions = existing.Conclusions?.ToList() ?? new List<TemplateConclusion>();
            }
        }
    }

    private void AddMarker(Marker marker)
    {
        if (selectedMarkers.Any(m => m.MarkerId == marker.Id)) return;

        var newList = selectedMarkers.ToList();
        newList.Add(new TemplateMarker
        {
            MarkerId = marker.Id,
            Marker = marker,
            DisplayOrder = newList.Any() ? newList.Max(x => x.DisplayOrder) + 1 : 1
        });
        selectedMarkers = newList;
        StateHasChanged();
    }

    private void RemoveMarker(TemplateMarker tm)
    {
        selectedMarkers.Remove(tm);
        ReorderMarkers();
    }

    private void ReorderMarkers()
    {
        var ordered = selectedMarkers.OrderBy(x => x.DisplayOrder).ToList();
        for (int i = 0; i < ordered.Count; i++)
            ordered[i].DisplayOrder = i + 1;
    }

    // --- Drag and Drop ---
    private void HandleDragStart(TemplateMarker item) => draggedItem = item;

    private void HandleDrop(TemplateMarker targetItem)
    {
        if (draggedItem == null || draggedItem == targetItem) return;

        var list = selectedMarkers.OrderBy(x => x.DisplayOrder).ToList();
        
        int oldIdx = list.IndexOf(draggedItem);
        int newIdx = list.IndexOf(targetItem);

        if (oldIdx != -1 && newIdx != -1)
        {
            list.RemoveAt(oldIdx);
            list.Insert(newIdx, draggedItem);
            
            // Re-assign DisplayOrder based on new positions
            for(int i = 0; i < list.Count; i++)
            {
                list[i].DisplayOrder = i + 1;
            }
            
            selectedMarkers = list;
            StateHasChanged();
        }
        
        draggedItem = null;
    }

    // --- Conclusions CRUD ---
    private void AddConclusion()
    {
        showNewConclusionForm = true;
        newConclusionText = "";
    }

    private async Task SaveNewConclusion()
    {
        if (string.IsNullOrWhiteSpace(newConclusionText)) return;

        // Template must be saved first
        if (template.Id == 0)
        {
            await MasterService.UpsertTemplateAsync(template, selectedMarkers);
        }

        var conclusion = new TemplateConclusion
        {
            ReportTemplateId = template.Id,
            Text = newConclusionText.Trim(),
            DisplayOrder = conclusions.Count + 1
        };
        await MasterService.UpsertTemplateConclusionAsync(conclusion);
        conclusions.Add(conclusion);
        showNewConclusionForm = false;
        newConclusionText = "";
    }

    private void StartEditConclusion(TemplateConclusion c)
    {
        editingConclusionId = c.Id;
        editingConclusionText = c.Text;
    }

    private async Task SaveEditedConclusion(TemplateConclusion c)
    {
        c.Text = editingConclusionText.Trim();
        await MasterService.UpsertTemplateConclusionAsync(c);
        editingConclusionId = 0;
    }

    private async Task DeleteConclusion(int id)
    {
        await MasterService.DeleteTemplateConclusionAsync(id);
        conclusions.RemoveAll(c => c.Id == id);
    }

    // --- Save Template ---
    private async Task SaveTemplate()
    {
        isSaving = true;
        try
        {
            await MasterService.UpsertTemplateAsync(template, selectedMarkers);
            Nav.NavigateTo("/configuracion");
        }
        finally
        {
            isSaving = false;
        }
    }
}
