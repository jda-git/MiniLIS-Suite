@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private List<Sample> samples = new();
    private bool isLoading = true;
    private Patient? previewPatient;

    private string searchTerm = "";
    private SampleStatus? statusFilter;
    private DateTime? fromDate;
    private DateTime? toDate;

    // Panel modal state
    private Sample? panelModalSample;
    private List<SamplePanel> modalPanels = new();
    private List<Panel> allPanelsForModal = new();
    private int modalAddPanelId = 0;
    private string? modalErrorMessage;
    private int? currentUserId;
    private string? currentUserName;

    private async Task ToggleReadInModal(SamplePanel sp, bool isRead)
    {
        sp.IsRead = isRead;
        if (isRead)
        {
            if (!currentUserId.HasValue)
            {
                var authState = await AuthStateTask;
                var user = await UserManager.GetUserAsync(authState.User);
                currentUserId = user?.Id;
                currentUserName = user?.FullName ?? user?.UserName;
            }
            sp.ReadByUserId = currentUserId;
            sp.ReadAt = DateTime.Now;
        }
        else
        {
            sp.ReadByUserId = null;
            sp.ReadAt = null;
            sp.ReadByUser = null;
        }
    }

    [Inject] private IMasterDataService MasterService { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        allPanelsForModal = (await MasterService.GetAllPanelsAsync()).OrderBy(p => p.DisplayOrder).ThenBy(p => p.Name).ToList();
        await LoadSamples();
    }

    private async Task LoadSamples()
    {
        isLoading = true;
        samples = await SampleService.GetFilteredSamplesAsync(searchTerm, statusFilter, fromDate, toDate);
        isLoading = false;
    }

    private async Task ApplyFilters() => await LoadSamples();

    private async Task ClearFilters()
    {
        searchTerm = "";
        statusFilter = null;
        fromDate = null;
        toDate = null;
        await LoadSamples();
    }

    private void ShowPreview(Patient? patient)
    {
        previewPatient = patient;
    }

    // --- Panel Modal ---
    private async Task OpenPanelModal(Sample sample)
    {
        panelModalSample = sample;
        modalAddPanelId = 0;
        modalErrorMessage = null;
        // Load fresh panels for this sample
        var panels = await SampleService.GetSamplePanelsAsync(sample.Id);
        modalPanels = panels.Select(p => new SamplePanel
        {
            Id = p.Id,
            SampleId = p.SampleId,
            PanelId = p.PanelId,
            Panel = p.Panel,
            IsRequested = p.IsRequested,
            IsRead = p.IsRead,
            ReadByUserId = p.ReadByUserId,
            ReadAt = p.ReadAt,
            ReadByUser = p.ReadByUser,
            DisplayOrder = p.DisplayOrder,
            CustomText = p.CustomText
        }).ToList();
    }

    private void AddPanelToModal()
    {
        if (modalAddPanelId == 0) return;
        var panel = allPanelsForModal.FirstOrDefault(p => p.Id == modalAddPanelId);
        if (panel == null) return;
        modalPanels.Add(new SamplePanel
        {
            PanelId = panel.Id,
            Panel = panel,
            IsRequested = true,
            IsRead = false,
            DisplayOrder = modalPanels.Count + 1
        });
        modalAddPanelId = 0;
    }

    private async Task SavePanelModal()
    {
        if (panelModalSample == null) return;
        modalErrorMessage = null;
        try
        {
            await SampleService.SetSamplePanelsAsync(panelModalSample.Id, modalPanels);
            panelModalSample = null;
            await LoadSamples(); // Refresh to show updated badges
        }
        catch (Microsoft.EntityFrameworkCore.DbUpdateConcurrencyException)
        {
            modalErrorMessage = "Error de concurrencia: La muestra ha sido modificada por otro usuario. Cierre este diálogo y refresque la bandeja de trabajo para cargar los datos más recientes.";
        }
        catch (Exception ex)
        {
            modalErrorMessage = $"Error al guardar paneles: {ex.Message}";
        }
    }

    private void ClosePanelModal()
    {
        panelModalSample = null;
        modalErrorMessage = null;
    }

    private string GetStatusClass(SampleStatus status) => status switch
    {
        SampleStatus.Recibida => "status-recibida",
        SampleStatus.EnProceso => "status-enproceso",
        SampleStatus.ReportadaParcial => "status-reportada",
        SampleStatus.Finalizada => "status-finalizada",
        SampleStatus.Rechazada => "status-rechazada",
        _ => ""
    };

    private string GetStatusLabel(SampleStatus status) => status switch
    {
        SampleStatus.Recibida => "recibida",
        SampleStatus.EnProceso => "en proceso",
        SampleStatus.ReportadaParcial => "rep. parcial",
        SampleStatus.Finalizada => "finalizada",
        SampleStatus.Rechazada => "rechazada",
        _ => status.ToString()
    };

    private void ExportExcel()
    {
        var url = $"/api/downloads/muestras/csv?t={DateTime.Now.Ticks}";
        JS.InvokeVoidAsync("triggerDownload", url);
    }
}
