@page "/estadisticas"
@using Microsoft.AspNetCore.Authorization
@using MiniLIS.Application.Interfaces
@using MiniLIS.Domain.Entities
@attribute [Authorize(Roles = "Administrador")]
@inject IStatisticsService StatsService
@inject IMasterDataService MasterService
@inject IJSRuntime JS

<PageTitle>Estadísticas - MiniLIS Suite</PageTitle>

<div class="stats-container animate-fade-in">
    <!-- Header -->
    <div class="stats-header d-flex align-items-center justify-content-between mb-4 p-4 rounded-3 text-white shadow-sm" style="background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);">
        <div>
            <h1 class="stats-title-main text-white m-0 d-flex align-items-center">
                <i class="bi bi-pie-chart-fill me-3 text-info fs-2"></i>
                Estadísticas y Reportes
            </h1>
            <p class="stats-subtitle-main text-info-emphasis opacity-75 m-0 mt-1">Análisis integral de TAT, incidencias y volumen de muestras</p>
        </div>
        <div class="stats-header-badge bg-info bg-opacity-25 border border-info border-opacity-50 text-info px-3 py-2 rounded-pill fs-7 fw-semibold d-none d-sm-inline-block">
            <i class="bi bi-shield-check me-1"></i> ISO 15189 Compliant
        </div>
    </div>

    <!-- Filters Section -->
    <div class="stats-card p-4 mb-4 shadow-sm border-0 bg-white">
        <div class="d-flex align-items-center mb-3">
            <span class="badge bg-primary-subtle text-primary me-2"><i class="bi bi-funnel-fill"></i></span>
            <h6 class="text-uppercase tracking-wider fw-bold text-muted m-0 fs-7">Filtros de Búsqueda</h6>
        </div>
        <div class="row align-items-end g-3">
            <div class="col-md-3">
                <label class="form-label-small">Desde</label>
                <div class="input-group input-group-sm">
                    <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-calendar-date"></i></span>
                    <input type="date" class="form-control form-control-sm stats-input border-start-0 ps-0" @bind="fromDate" />
                </div>
            </div>
            <div class="col-md-3">
                <label class="form-label-small">Hasta</label>
                <div class="input-group input-group-sm">
                    <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-calendar-date"></i></span>
                    <input type="date" class="form-control form-control-sm stats-input border-start-0 ps-0" @bind="toDate" />
                </div>
            </div>
            <div class="col-md-3">
                <label class="form-label-small">Panel de Estudio</label>
                <div class="input-group input-group-sm">
                    <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-funnel"></i></span>
                    <select class="form-select form-select-sm stats-input border-start-0 ps-0" @bind="selectedPanel">
                        <option value="Todos">Todos los paneles</option>
                        @foreach (var p in allPanels)
                        {
                            <option value="@p.Name">@p.Name</option>
                        }
                    </select>
                </div>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button class="btn btn-info btn-sm text-white w-100 fw-semibold d-flex align-items-center justify-content-center btn-calc shadow-sm" @onclick="CalculateStats" disabled="@isCalculating">
                    @if (isCalculating)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                        <span>Procesando...</span>
                    }
                    else
                    {
                        <i class="bi bi-arrow-repeat me-2 animate-spin-hover"></i>
                        <span>Actualizar Datos</span>
                    }
                </button>
            </div>
        </div>
    </div>

    @if (summary != null)
    {
        <!-- Summary Cards -->
        <div class="row mb-4 g-3">
            <div class="col-md-3 col-sm-6">
                <div class="summary-box border-start-primary shadow-sm">
                    <div class="summary-content">
                        <div class="summary-label">Muestras Totales</div>
                        <div class="summary-value">@summary.TotalSamples</div>
                    </div>
                    <div class="summary-icon bg-primary-soft text-primary"><i class="bi bi-folder-fill"></i></div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="summary-box border-start-info shadow-sm">
                    <div class="summary-content">
                        <div class="summary-label">TAT Medio</div>
                        <div class="summary-value">@summary.AverageTatHours h</div>
                    </div>
                    <div class="summary-icon bg-info-soft text-info"><i class="bi bi-speedometer2"></i></div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="summary-box border-start-warning shadow-sm">
                    <div class="summary-content">
                        <div class="summary-label">Incidencias</div>
                        <div class="summary-value">@summary.TotalIncidents</div>
                    </div>
                    <div class="summary-icon bg-warning-soft text-warning"><i class="bi bi-exclamation-triangle-fill"></i></div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="summary-box border-start-danger shadow-sm">
                    <div class="summary-content">
                        <div class="summary-label">% Incidencias</div>
                        <div class="summary-value">@summary.IncidentPercentage %</div>
                    </div>
                    <div class="summary-icon bg-danger-soft text-danger"><i class="bi bi-graph-down-arrow"></i></div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <!-- TAT List -->
            <div class="col-lg-6">
                <div class="stats-card border-0 shadow-sm bg-white">
                    <div class="card-header-custom border-0 bg-light-subtle py-3 px-4">
                        <h5 class="fw-bold d-flex align-items-center m-0"><i class="bi bi-alarm-fill text-success me-2"></i>Detalle de TAT (Finalizadas)</h5>
                        <button class="btn btn-outline-success btn-xs fw-semibold px-2 py-1" @onclick="ExportTat">
                            <i class="bi bi-file-earmark-excel-fill me-1"></i>Excel
                        </button>
                    </div>
                    <div class="card-body-scroll px-4 pb-3">
                        <table class="table table-hover stats-table align-middle">
                            <thead>
                                <tr>
                                    <th>Muestra</th>
                                    <th>Recepción</th>
                                    <th class="text-end">TAT</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in tatDetails)
                                {
                                    <tr>
                                        <td class="fw-bold text-dark">@item.SampleNumber</td>
                                        <td class="text-muted">@item.ReceptionDate.ToString("dd/MM/yyyy")</td>
                                        <td class="text-end">
                                            <span class="badge @(item.Hours > 48 ? "bg-danger-subtle text-danger" : "bg-success-subtle text-success") px-2.5 py-1.5 rounded">
                                                @item.Hours h
                                            </span>
                                        </td>
                                    </tr>
                                }
                                @if (!tatDetails.Any())
                                {
                                    <tr><td colspan="3" class="text-center text-muted py-5"><i class="bi bi-info-circle me-1"></i> No hay muestras finalizadas en el rango seleccionado</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Incidents List -->
            <div class="col-lg-6">
                <div class="stats-card border-0 shadow-sm bg-white">
                    <div class="card-header-custom border-0 bg-light-subtle py-3 px-4">
                        <h5 class="fw-bold d-flex align-items-center m-0"><i class="bi bi-shield-fill-exclamation text-warning me-2"></i>Listado de Incidencias</h5>
                        <button class="btn btn-outline-success btn-xs fw-semibold px-2 py-1" @onclick="ExportIncidents">
                            <i class="bi bi-file-earmark-excel-fill me-1"></i>Excel
                        </button>
                    </div>
                    <div class="card-body-scroll px-4 pb-3">
                        <table class="table table-hover stats-table align-middle">
                            <thead>
                                <tr>
                                    <th>Muestra</th>
                                    <th>Paciente</th>
                                    <th>Incidencia</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in incidentDetails)
                                {
                                    <tr>
                                        <td class="fw-bold text-dark" style="white-space: nowrap;">@item.SampleNumber</td>
                                        <td class="text-truncate fw-semibold text-muted" style="max-width: 130px;">@item.Patient</td>
                                        <td>
                                            <div class="incident-badge-notes rounded p-2 text-dark bg-warning-subtle fs-7 text-wrap" style="max-width: 250px;">
                                                @item.IncidentNotes
                                            </div>
                                        </td>
                                    </tr>
                                }
                                @if (!incidentDetails.Any())
                                {
                                    <tr><td colspan="3" class="text-center text-muted py-5"><i class="bi bi-emoji-smile me-1"></i> Sin incidencias registradas en este rango</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .stats-container { padding: 1.5rem; max-width: 1200px; margin: 0 auto; }
    
    /* Animations */
    .animate-fade-in {
        animation: fadeIn 0.4s ease-out forwards;
    }
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(8px); }
        to { opacity: 1; transform: translateY(0); }
    }
    
    /* Header Styling */
    .stats-title-main { font-size: 1.6rem; font-weight: 700; }
    .stats-subtitle-main { font-size: 0.9rem; }
    
    /* Card Styling */
    .stats-card {
        border-radius: 12px;
        box-shadow: 0 4px 18px rgba(15, 23, 42, 0.03); 
        overflow: hidden;
        border: 1px solid #f1f5f9;
        transition: all 0.25s ease;
    }
    .stats-card:hover {
        box-shadow: 0 6px 24px rgba(15, 23, 42, 0.05);
    }
    
    .form-label-small { 
        font-size: 0.72rem; 
        font-weight: 700; 
        color: #64748b; 
        text-transform: uppercase; 
        margin-bottom: 6px; 
        display: block; 
        letter-spacing: 0.05em;
    }
    .stats-input { 
        border-radius: 6px; 
        border: 1px solid #cbd5e1; 
        font-size: 0.85rem; 
        padding: 0.375rem 0.75rem;
        transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }
    .stats-input:focus {
        border-color: #0ea5e9;
        box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.15);
    }
    
    /* Button Calc Animation */
    .btn-calc {
        transition: all 0.2s ease;
        font-size: 0.85rem;
        padding: 0.45rem 1rem;
        background-color: #0ea5e9;
        border-color: #0ea5e9;
    }
    .btn-calc:hover:not(:disabled) {
        background-color: #0284c7;
        border-color: #0284c7;
        transform: translateY(-1px);
        box-shadow: 0 4px 10px rgba(14, 165, 233, 0.25);
    }
    .btn-calc:active:not(:disabled) {
        transform: translateY(0);
    }
    .animate-spin-hover {
        transition: transform 0.4s ease;
    }
    .btn-calc:hover .animate-spin-hover {
        transform: rotate(180deg);
    }
    
    /* Metrics Boxes - Modern Design */
    .summary-box {
        background: white; 
        border: 1px solid #f1f5f9; 
        border-radius: 12px;
        padding: 1.25rem; 
        display: flex;
        align-items: center;
        justify-content: space-between;
        box-shadow: 0 4px 12px rgba(15, 23, 42, 0.02);
        position: relative;
        overflow: hidden;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .summary-box:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 20px rgba(15, 23, 42, 0.06);
    }
    
    /* Color accents for cards */
    .border-start-primary { border-left: 4px solid #0f172a; }
    .border-start-info { border-left: 4px solid #0ea5e9; }
    .border-start-warning { border-left: 4px solid #f59e0b; }
    .border-start-danger { border-left: 4px solid #ef4444; }
    
    .summary-content {
        display: flex;
        flex-direction: column;
        z-index: 2;
    }
    .summary-label { color: #64748b; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; }
    .summary-value { font-size: 1.65rem; font-weight: 800; color: #0f172a; margin-top: 4px; line-height: 1; }
    
    .summary-icon { 
        width: 48px;
        height: 48px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem; 
        z-index: 1;
        transition: transform 0.3s ease;
    }
    .summary-box:hover .summary-icon {
        transform: scale(1.08);
    }
    
    /* Soft background colors for icons */
    .bg-primary-soft { background-color: rgba(15, 23, 42, 0.06); }
    .bg-info-soft { background-color: rgba(14, 165, 233, 0.08); }
    .bg-warning-soft { background-color: rgba(245, 158, 11, 0.08); }
    .bg-danger-soft { background-color: rgba(239, 68, 68, 0.08); }

    .card-header-custom {
        display: flex; justify-content: space-between; align-items: center;
        border-bottom: 1px solid #f1f5f9;
    }
    .card-header-custom h5 { font-size: 0.95rem; font-weight: 700; color: #334155; }
    
    .card-body-scroll { max-height: 380px; overflow-y: auto; }
    
    /* Custom Scrollbar for scrollable panels */
    .card-body-scroll::-webkit-scrollbar {
        width: 6px;
    }
    .card-body-scroll::-webkit-scrollbar-track {
        background: transparent;
    }
    .card-body-scroll::-webkit-scrollbar-thumb {
        background-color: #cbd5e1;
        border-radius: 3px;
    }
    .card-body-scroll::-webkit-scrollbar-thumb:hover {
        background-color: #94a3b8;
    }
    
    .stats-table { margin-bottom: 0; }
    .stats-table thead th { 
        position: sticky; top: 0; background: #fafafa; z-index: 10;
        font-size: 0.72rem; color: #64748b; font-weight: 700; text-transform: uppercase;
        padding: 12px 8px; border-bottom: 1px solid #e2e8f0; border-top: 0;
        letter-spacing: 0.05em;
    }
    .stats-table tbody td { padding: 12px 8px; font-size: 0.85rem; border-bottom: 1px solid #f1f5f9; }
    .stats-table tbody tr:last-child td { border-bottom: 0; }

    .btn-xs { padding: 4px 8px; font-size: 0.75rem; border-radius: 4px; }
    
    /* Badge customizations */
    .bg-success-subtle { background-color: #dcfce7; color: #15803d; }
    .bg-danger-subtle { background-color: #fee2e2; color: #b91c1c; }
    
    .incident-badge-notes {
        font-size: 0.78rem;
        line-height: 1.4;
        border-radius: 6px;
        border-left: 3px solid #f59e0b;
        padding: 6px 10px;
    }
</style>

@code {
    private DateTime fromDate = DateTime.Today.AddMonths(-1);
    private DateTime toDate = DateTime.Today;
    private string selectedPanel = "Todos";
    private List<Panel> allPanels = new();
    private bool isCalculating = false;
    
    private StatisticsSummary? summary;
    private List<TatStatItem> tatDetails = new();
    private List<IncidentStatItem> incidentDetails = new();

    protected override async Task OnInitializedAsync()
    {
        allPanels = (await MasterService.GetAllPanelsAsync()).OrderBy(p => p.Name).ToList();
        await CalculateStats();
    }

    private async Task CalculateStats()
    {
        isCalculating = true;
        try
        {
            summary = await StatsService.GetSummaryAsync(fromDate, toDate, selectedPanel);
            tatDetails = await StatsService.GetTatDetailsAsync(fromDate, toDate, selectedPanel);
            incidentDetails = await StatsService.GetIncidentDetailsAsync(fromDate, toDate);
        }
        finally
        {
            isCalculating = false;
        }
    }

    private async Task ExportTat()
    {
        var csv = await StatsService.ExportTatToCsvAsync(tatDetails);
        var fileName = $"TAT_{fromDate:yyyyMMdd}_{toDate:yyyyMMdd}.csv";
        await DownloadFile(csv, fileName);
    }

    private async Task ExportIncidents()
    {
        var csv = await StatsService.ExportIncidentsToCsvAsync(incidentDetails);
        var fileName = $"Incidencias_{fromDate:yyyyMMdd}_{toDate:yyyyMMdd}.csv";
        await DownloadFile(csv, fileName);
    }

    private async Task DownloadFile(byte[] data, string fileName)
    {
        var base64 = Convert.ToBase64String(data);
        await JS.InvokeVoidAsync("downloadFileFromBase64", fileName, base64);
    }
}
