@page "/informes/editar/{SampleId:int}"
@using MiniLIS.Application.Interfaces
@using MiniLIS.Domain.Entities
@using Microsoft.AspNetCore.Authorization
@using MiniLIS.Domain.Identity
@attribute [Authorize]
@inject NavigationManager Nav
@inject IReportService ReportService
@inject IMasterDataService MasterService
@inject IDocumentService DocumentService
@inject IJSRuntime JS

<PageTitle>Editor de Informe - MiniLIS Suite</PageTitle>

<div class="rpt-page">

    @if (report == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="text-muted mt-3">Cargando datos del informe...</p>
        </div>
    }
    else
    {
    <!-- ═══════════════  SECCIÓN 1 · IDENTIFICACIÓN  ═══════════════ -->
    <fieldset class="rpt-fieldset">
        <legend>Identificación</legend>
        <div class="id-grid">
            <div class="id-field"><label>Nombre:</label><input type="text" @bind="patientName" /></div>
            <div class="id-field"><label>Fecha muestra:</label><input type="text" value="@report.Sample?.ReceptionDate.ToString("dd/MM/yyyy")" readonly /></div>
            <div class="id-field"><label>Fecha informe:</label><input type="date" @bind="reportDate" /></div>

            <div class="id-field"><label>Nº muestra:</label><input type="text" value="@report.Sample?.SampleNumber" readonly /></div>
            <div class="id-field"><label>Petición electrónica:</label><input type="text" @bind="peticionElectronica" /></div>
            <div class="id-field"><label>NHC:</label><input type="text" value="@report.Sample?.ClinicalRequest?.Patient?.NHC" readonly /></div>
            <div class="id-field id-field-sm"><label>NASI:</label><input type="text" value="@report.Sample?.ClinicalRequest?.Patient?.NASI" readonly /></div>

            <div class="id-field id-field-wide"><label>Motivo solicitud:</label><input type="text" @bind="motivoSolicitud" /></div>
            <div class="id-field"><label>Servicio solicitante:</label><input type="text" @bind="servicioSolicitante" /></div>
            <div class="id-field"><label>Médico solicitante:</label><input type="text" @bind="medicoSolicitante" /></div>
        </div>
        <div class="id-grid mt-2">
            <div class="id-field">
                <label>Tipo de muestra:</label>
                <div class="d-flex align-items-center gap-3 ms-2">
                    <label class="rpt-radio"><input type="radio" name="tmuestra" checked="@(tipoMuestra == "SP")" @onchange="@(() => tipoMuestra = "SP")" /> SP</label>
                    <label class="rpt-radio"><input type="radio" name="tmuestra" checked="@(tipoMuestra == "MO")" @onchange="@(() => tipoMuestra = "MO")" /> MO</label>
                    <label class="rpt-radio"><input type="radio" name="tmuestra" checked="@(tipoMuestra == "LCR")" @onchange="@(() => tipoMuestra = "LCR")" /> LCR</label>
                    <label class="rpt-radio"><input type="radio" name="tmuestra" checked="@(tipoMuestra == "Otros")" @onchange="@(() => tipoMuestra = "Otros")" /> Otros</label>
                    @if(tipoMuestra == "Otros")
                    {
                        <input type="text" @bind="otroTipoMuestra" class="form-control form-control-sm" style="width: 130px; font-size: 13px; height: 26px; margin-left: 8px;" placeholder="Especificar..." />
                    }
                </div>
            </div>
        </div>
    </fieldset>

    <!-- ═══════════════  SECCIÓN 2 · INFORME  ═══════════════ -->
    <fieldset class="rpt-fieldset mt-3">
        <legend>Informe</legend>

        <!-- Plantilla selector -->
        <div class="d-flex align-items-center gap-3 mb-3">
            <label class="rpt-label">Plantilla:</label>
            <select class="rpt-select" style="width: 260px;" @onchange="OnTemplateSelected">
                <option value="">-- Seleccionar --</option>
                @foreach (var t in availableTemplates)
                {
                    <option value="@t.Id" selected="@(report.TemplateId == t.Id)">@t.Name</option>
                }
            </select>
        </div>

        <!-- Texto del informe -->
        <div class="mb-3">
            <label class="rpt-label">Texto del informe:</label>
            <textarea class="rpt-textarea" rows="5" @bind="report.ReportBody"></textarea>
        </div>

        <!-- Marcadores -->
        <div class="mb-3">
            <label class="rpt-label">Marcadores:</label>
            <div class="rpt-markers-box">
                @foreach (var val in report.MarkerValues.OrderBy(v => v.DisplayOrder))
                {
                    <div class="marker-row">
                        <span class="marker-name">@val.Marker?.Name</span>
                        <div class="marker-intensities">
                            @foreach (var intensity in intensityOptions)
                            {
                                <label class="intensity-radio">
                                    <input type="radio" name="mk-@val.MarkerId-@val.DisplayOrder"
                                           checked="@(val.IntensityValue == intensity)"
                                           @onchange="@(() => { val.IntensityValue = intensity; RecalculateSummary(); })" />
                                    @intensity
                                </label>
                            }
                            <label class="intensity-radio intensity-het">
                                <input type="radio" name="mk-@val.MarkerId-@val.DisplayOrder"
                                       checked="@(val.IntensityValue == "Heterogéneo")"
                                       @onchange="@(() => { val.IntensityValue = "Heterogéneo"; RecalculateSummary(); })" />
                                Heterogéneo
                            </label>
                        </div>
                        <div class="marker-pct">
                            <input type="text" class="pct-input" placeholder="%" @bind="val.Percentage" @bind:event="oninput" @onkeyup="RecalculateSummary" />
                        </div>
                        <button type="button" class="marker-clear" title="Limpiar" @onclick="@(() => { val.IntensityValue = null; val.Percentage = null; RecalculateSummary(); })">
                            <i class="bi bi-x text-danger"></i>
                        </button>
                    </div>
                }
            </div>
        </div>

        <!-- Texto adicional -->
        <div class="mb-3">
            <label class="rpt-label">Texto adicional (opcional):</label>
            <textarea class="rpt-textarea" rows="2" @bind="report.AdditionalText" placeholder="Texto libre que aparecerá debajo de los marcadores en el informe..."></textarea>
        </div>
    </fieldset>

    <!-- ═══════════════  SECCIÓN 3 · CONCLUSIÓN  ═══════════════ -->
    <fieldset class="rpt-fieldset mt-3">
        <legend>Conclusión</legend>
        <div class="mb-2">
            <label class="rpt-label">Conclusión predefinida:</label>
            <select class="rpt-select" @onchange="OnConclusionSelected">
                <option value="">-- Seleccionar conclusión --</option>
                @foreach (var c in templateConclusions)
                {
                    <option value="@c.Id">@(c.Text.Length > 100 ? c.Text.Substring(0, 97) + "..." : c.Text)</option>
                }
            </select>
        </div>
        <textarea class="rpt-textarea" rows="4" @bind="report.Conclusions" placeholder="Texto de la conclusión (editable)..."></textarea>
    </fieldset>

    <!-- ═══════════════  SECCIÓN 4 · PANELES  ═══════════════ -->
    <fieldset class="rpt-fieldset mt-3">
        <legend>Paneles</legend>
        <div class="mb-2">
            <label class="rpt-label">Paneles:</label>
            <select class="rpt-select" style="width: 280px;" @onchange="OnPanelSelected">
                <option value="">-- Seleccionar panel --</option>
                @foreach (var p in availablePanels)
                {
                    <option value="@p.Id" selected="@(report.PanelId == p.Id)">@p.Name</option>
                }
            </select>
        </div>
        <div>
            <label class="rpt-label">Paneles empleados:</label>
            <textarea class="rpt-textarea" rows="3" @bind="report.PanelsUsedText" placeholder="Listado de tubos empleados..."></textarea>
        </div>
    </fieldset>

    <!-- ═══════════════  SECCIÓN 5 · FIRMAS  ═══════════════ -->
    <fieldset class="rpt-fieldset mt-3">
        <legend>Firmas</legend>
        <div class="d-flex flex-wrap gap-4 py-2 px-1">
            @foreach (var user in availableSignatories)
            {
                <label class="rpt-signatory">
                    <input type="checkbox" checked="@selectedSignatoryIds.Contains(user.Id)"
                           @onchange="@(e => ToggleSignatory(user.Id, e.Value))" />
                    @user.FullName
                </label>
            }
        </div>
    </fieldset>

    <!-- ═══════════════  BOTONES  ═══════════════ -->
    <div class="rpt-actions mt-4 mb-5">
        <button class="btn btn-light border px-4" @onclick='() => Nav.NavigateTo("/muestras")'>
            <i class="bi bi-arrow-left me-2"></i>Volver
        </button>

        <div class="d-flex gap-2">
            @if (report?.Id > 0)
            {
                <a href="/api/downloads/informe/@report.Id/pdf?t=@DateTime.Now.Ticks" 
                   target="_blank" download class="btn btn-outline-danger px-3">
                    <i class="bi bi-file-pdf me-2"></i>PDF
                </a>
                <a href="/api/downloads/informe/@report.Id/odt?t=@DateTime.Now.Ticks" 
                   target="_blank" download class="btn btn-outline-info px-3">
                    <i class="bi bi-file-earmark-word me-2"></i>ODT
                </a>
            }
            <button class="btn btn-primary px-5 fw-bold shadow-sm" disabled="@isSaving" @onclick="SaveAndNotify">
                @if (isSaving) { <span class="spinner-border spinner-border-sm me-2"></span> }
                <i class="bi bi-check-lg me-2"></i>Guardar Informe
            </button>
        </div>
    </div>
    }
</div>

<style>
    .rpt-page { padding: 24px 32px; background: #f4f6f9; min-height: calc(100vh - 56px); font-family: 'Segoe UI', system-ui, sans-serif; max-width: 1050px; }

    .rpt-fieldset {
        border: 1px solid #c0c0c0;
        border-radius: 4px;
        padding: 14px 18px 18px;
        background: #fff;
    }
    .rpt-fieldset legend {
        font-size: 13px;
        font-weight: 700;
        color: #334155;
        padding: 0 8px;
        width: auto;
        float: none;
    }

    .id-grid { display: flex; flex-wrap: wrap; gap: 10px 24px; padding: 4px; }
    .id-field { display: flex; align-items: center; gap: 8px; }
    .id-field label { font-size: 13px; color: #555; font-weight: 600; white-space: nowrap; margin: 0; width: 130px; text-align: right; }
    .id-field input[type="text"], .id-field input[type="date"] { font-size: 13px; border: 1px solid #ccc; border-radius: 3px; padding: 3px 8px; height: 28px; width: 180px; background: #fafafa; }
    .id-field input[type="text"]:focus, .id-field input[type="date"]:focus { border-color: #86b7fe; outline: none; background: #fff; }
    .id-field input[readonly] { background: #e9ecef; color: #495057; }
    .id-field-sm input[type="text"] { width: 80px; }
    .id-field-wide input[type="text"] { width: 280px; }

    .rpt-radio { font-size: 13px; display: inline-flex; align-items: center; gap: 6px; cursor: pointer; margin: 0; white-space: nowrap; }
    .rpt-radio input[type="radio"] { accent-color: #0d6efd; margin: 0; width: 14px; height: 14px; }

    .rpt-label { font-size: 12px; font-weight: 700; color: #334155; margin-bottom: 4px; display: block; }
    .rpt-select { font-size: 13px; border: 1px solid #ccc; border-radius: 3px; padding: 4px 8px; height: 30px; background: #fff; }
    .rpt-textarea { font-size: 13px; width: 100%; border: 1px solid #ccc; border-radius: 3px; padding: 8px 10px; font-family: 'Consolas', 'Courier New', monospace; resize: vertical; }

    /* ── Markers grid ── */
    .rpt-markers-box { border: 1px solid #ddd; border-radius: 4px; padding: 8px; background: #fafafa; max-height: 500px; overflow-y: auto; }
    .marker-row { display: flex; align-items: center; gap: 8px; padding: 4px 0; border-bottom: 1px solid #eee; }
    .marker-row:last-child { border-bottom: none; }
    .marker-name { font-size: 13px; font-weight: 700; color: #1e293b; width: 80px; text-align: right; flex-shrink: 0; }
    .marker-intensities { display: flex; flex-wrap: wrap; gap: 2px; flex: 1; }
    .intensity-radio { font-size: 11px; display: inline-flex; align-items: center; gap: 2px; cursor: pointer; white-space: nowrap; padding: 1px 4px; border-radius: 3px; margin: 0; }
    .intensity-radio:hover { background: #eef2f7; }
    .intensity-radio input { accent-color: #2563eb; width: 12px; height: 12px; margin: 0; }
    .intensity-het { color: #b45309; }
    .marker-pct { width: 50px; flex-shrink: 0; }
    .pct-input { width: 100%; font-size: 12px; border: 1px solid #ddd; border-radius: 3px; padding: 2px 6px; text-align: center; height: 24px; }
    .marker-clear { background: none; border: none; padding: 2px; cursor: pointer; font-size: 14px; }

    /* ── Signatories ── */
    .rpt-signatory { font-size: 13px; display: flex; align-items: center; gap: 6px; cursor: pointer; margin: 0; }
    .rpt-signatory input { accent-color: #0d6efd; }

    /* ── Actions ── */
    .rpt-actions { display: flex; justify-content: space-between; align-items: center; }
</style>

@code {
    [Parameter] public int SampleId { get; set; }

    private SampleReport? report;
    private List<ReportTemplate> availableTemplates = new();
    private List<Panel> availablePanels = new();
    private List<ApplicationUser> availableSignatories = new();
    private List<TemplateConclusion> templateConclusions = new();
    private List<int> selectedSignatoryIds = new();
    private List<string> intensityOptions = new();
    private bool isSaving = false;

    // Identification fields (editable)
    private string patientName = "";
    private DateTime reportDate = DateTime.Today;
    private string peticionElectronica = "";
    private string motivoSolicitud = "";
    private string servicioSolicitante = "";
    private string medicoSolicitante = "";
    private string tipoMuestra = "MO";
    private string otroTipoMuestra = "";

    protected override async Task OnInitializedAsync()
    {
        report = await ReportService.GetOrCreateReportAsync(SampleId);
        availableTemplates = await MasterService.GetAllTemplatesAsync();
        availablePanels = await MasterService.GetAllPanelsAsync();
        availableSignatories = await ReportService.GetAvailableSignatoriesAsync();

        var intensities = await MasterService.GetIntensitySettingsAsync();
        intensityOptions = intensities.Select(i => i.Value).ToList();

        // Populate identification from sample data
        var patient = report.Sample?.ClinicalRequest?.Patient;
        patientName = patient?.FullName ?? "";
        peticionElectronica = report.Sample?.ClinicalRequest?.RequestNumber ?? "";
        servicioSolicitante = report.Sample?.ClinicalRequest?.OriginService ?? "";
        medicoSolicitante = report.Sample?.ClinicalRequest?.DoctorName ?? "";

        // Parse tipo muestra from Diagnosis if available
        var diag = report.Sample?.Diagnosis ?? "";
        var typeMatch = System.Text.RegularExpressions.Regex.Match(diag, @"\[TIPO:\s*(.+?)\]");
        if (typeMatch.Success)
        {
            var t = typeMatch.Groups[1].Value.Trim();
            if (t == "SP" || t == "MO" || t == "LCR") {
                tipoMuestra = t;
            } else {
                tipoMuestra = "Otros";
                otroTipoMuestra = t;
            }
            motivoSolicitud = diag.Replace(typeMatch.Value, "").Trim();
        }
        else
        {
            motivoSolicitud = diag;
        }

        reportDate = report.ReportDate ?? DateTime.Today;

        // Load existing signatories
        if (report.Signatories.Any())
            selectedSignatoryIds = report.Signatories.Select(s => s.UserId).ToList();

        // Load conclusions if template already selected
        if (report.TemplateId.HasValue)
            templateConclusions = await MasterService.GetTemplateConclusionsAsync(report.TemplateId.Value);
    }

    private async Task OnTemplateSelected(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int templateId))
        {
            var template = await MasterService.GetTemplateWithMarkersAsync(templateId);
            if (template != null)
            {
                report!.TemplateId = templateId;
                report.ReportBody = template.HeaderText;

                // Load markers
                report.MarkerValues.Clear();
                foreach (var tm in template.Markers.OrderBy(m => m.DisplayOrder))
                {
                    report.MarkerValues.Add(new ReportMarkerValue
                    {
                        MarkerId = tm.MarkerId,
                        Marker = tm.Marker,
                        DisplayOrder = tm.DisplayOrder
                    });
                }

                // Load conclusions for this template
                templateConclusions = template.Conclusions?.ToList() ?? new List<TemplateConclusion>();

                // Set default conclusion if exists
                if (!string.IsNullOrEmpty(template.DefaultConclusion))
                    report.Conclusions = template.DefaultConclusion;

                RecalculateSummary();
            }
        }
    }

    private void OnConclusionSelected(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int conclusionId))
        {
            var conclusion = templateConclusions.FirstOrDefault(c => c.Id == conclusionId);
            if (conclusion != null)
                report!.Conclusions = conclusion.Text;
        }
    }

    private void OnPanelSelected(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int panelId))
        {
            var panel = availablePanels.FirstOrDefault(p => p.Id == panelId);
            if (panel != null)
            {
                report!.PanelId = panelId;
                report.PanelsUsedText = panel.TubeListText ?? "";
            }
        }
    }

    private void ToggleSignatory(int userId, object? isChecked)
    {
        if (isChecked is bool checkedValue && checkedValue)
        {
            if (!selectedSignatoryIds.Contains(userId)) selectedSignatoryIds.Add(userId);
        }
        else
        {
            selectedSignatoryIds.Remove(userId);
        }
    }

    private void RecalculateSummary()
    {
        if (report != null)
        {
            report.MarkersSummary = ReportService.GenerateMarkersSummary(report.MarkerValues);
            StateHasChanged();
        }
    }

    private async Task DownloadPdf()
    {
        await Save();
        var url = $"/api/downloads/informe/{report!.Id}/pdf?t={DateTime.Now.Ticks}";
        await JS.InvokeVoidAsync("triggerDownload", url);
    }

    private async Task DownloadOdt()
    {
        await Save();
        var url = $"/api/downloads/informe/{report!.Id}/odt?t={DateTime.Now.Ticks}";
        await JS.InvokeVoidAsync("triggerDownload", url);
    }

    private async Task SaveAndNotify()
    {
        await Save();
        await JS.InvokeVoidAsync("alert", "Informe guardado correctamente.");
    }

    private async Task Save()
    {
        isSaving = true;
        try
        {
            report!.ReportDate = reportDate;

            // Optional: Write back edited fields to report/sample so PDF generation sees them.
            if(report.Sample != null)
            {
                if(report.Sample.ClinicalRequest != null)
                {
                    if(report.Sample.ClinicalRequest.Patient != null)
                        report.Sample.ClinicalRequest.Patient.FullName = patientName;
                    
                    report.Sample.ClinicalRequest.RequestNumber = peticionElectronica;
                    report.Sample.ClinicalRequest.OriginService = servicioSolicitante;
                    report.Sample.ClinicalRequest.DoctorName = medicoSolicitante;
                }
                
                var t = tipoMuestra == "Otros" && !string.IsNullOrWhiteSpace(otroTipoMuestra) ? otroTipoMuestra : tipoMuestra;
                report.Sample.Diagnosis = string.IsNullOrWhiteSpace(t) ? motivoSolicitud : $"[TIPO: {t}] {motivoSolicitud}";
            }

            await ReportService.SaveReportAsync(report!, report!.MarkerValues.ToList(), selectedSignatoryIds);
        }
        finally
        {
            isSaving = false;
        }
    }
}
