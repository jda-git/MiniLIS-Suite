                    </div>
                    <a class="nav-link text-danger" href="/account/logout">
                        <span class="bi bi-box-arrow-right" aria-hidden="true"></span> Cerrar Sesión
                    </a>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="login">
                         Iniciar Sesión
                    </NavLink>
